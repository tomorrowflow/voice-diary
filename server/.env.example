# Database
DATABASE_URL=postgresql://diary:diary@postgres:5432/diary_processor

# Whisper ASR sidecar (in-stack)
# Image tag picks CPU vs GPU build of onerahmet/openai-whisper-asr-webservice:
#   latest       — CPU
#   latest-gpu   — CUDA (also uncomment the deploy.resources block in docker-compose.yml)
WHISPER_IMAGE_TAG=latest
WHISPER_MODEL=medium
WHISPER_ENGINE=faster_whisper
WHISPER_URL=http://whisper:9000

# Ollama (LLM validation + analysis + narrative generation)
OLLAMA_BASE_URL=http://192.168.2.17:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=131072
LLM_VALIDATION_ENABLED=true

# Timezone for calendar event display (default: Europe/Berlin)
TZ=Europe/Berlin

# Harvest time tracking (https://id.getharvest.com/developers)
HARVEST_ACCESS_TOKEN=your-personal-access-token-here
HARVEST_ACCOUNT_ID=your-account-id-here
HARVEST_USER_ID=user-id-for-sample-data

# Qdrant vector store (contextual learning)
QDRANT_URL=http://qdrant:6333
VECTOR_SEARCH_ENABLED=true

# LightRAG (external service)
LIGHTRAG_URL=http://192.168.2.16:9621
LIGHTRAG_API_KEY=

# Microsoft Graph (added in Server S2)
# MSGRAPH_CLIENT_ID=
# MSGRAPH_TENANT_ID=

# iOS bearer token (added in Server S2/S3, generate with: openssl rand -hex 32)
# IOS_BEARER_TOKEN=
