# macOS
.DS_Store

# Editors / tooling
.claude/
.automaker/
.planning/
.worktrees/
.idea/
.vscode/
*.swp

# Python
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Server runtime + secrets
server/.env
server/data/
server/**/data/sessions/
server/**/data/msal_cache.bin

# Node (in case any tooling lands)
node_modules/

# Design-system build pipeline.
# - tokens/ + config.js + scripts are tracked.
# - generated outputs (build/) land in ios/Sources/DesignSystem/ and
#   server/webapp/static/ via scripts/build_design_system.sh.
docs/design-system/build/
docs/design-system/.cache/

# Xcode / iOS
ios/build/
ios/DerivedData/
ios/**/xcuserdata/
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.xcodeproj/project.xcworkspace/xcuserdata/
# XcodeGen owns the Xcode project — generated, not tracked.
ios/VoiceDiary.xcodeproj/
ios/.build/
ios/Package.resolved
*.ipa
*.dSYM.zip
*.dSYM

# Piper TTS bootstrap (M9). Populated by ios/scripts/fetch_piper_voices.sh.
# Binary frameworks (~60 MB), upstream Swift bindings, VITS voice models
# (~120 MB each), the bootstrap-generated XcodeGen overlay — none belong
# in git.
ios/Frameworks/
ios/Sources/TTS/Vendor/
ios/Resources/Models/Voices/
ios/project-piper.yml
ios/.cache/
